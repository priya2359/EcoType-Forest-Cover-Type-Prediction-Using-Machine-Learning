# EcoType Environment Variables
# Copy this file to .env and fill in values

# API Settings
API_URL=http://localhost:8000
PORT=8000

# Model Source: 'local' (dev) or 'huggingface' (production)
MODEL_SOURCE=local

# HuggingFace — fill in when MODEL_SOURCE=huggingface
HF_REPO_ID=yourname/ecotype-models
HF_TOKEN=

# MLflow
MLFLOW_TRACKING_URI=mlruns/

# Artifact Paths (relative to project root)
MODEL_PATH=models/best_model/ecotype_best_model.pkl
SCALER_PATH=models/scalers/standard_scaler.pkl
WILDERNESS_OHE_PATH=models/encoders/wilderness_ohe.pkl
SOIL_OHE_PATH=models/encoders/soil_ohe.pkl
FEATURE_COLUMNS_PATH=artifacts/feature_columns.txt
QUANT_FEATURE_COLUMNS_PATH=artifacts/quant_feature_columns.txt

# Runtime
RANDOM_STATE=42
FAST_MODE=False

# API Production Settings (set these in Render dashboard)
MODEL_VERSION=1.0.0
RATE_LIMIT=60/minute
ALLOWED_ORIGINS=https://your-app.streamlit.app
CONFIDENCE_THRESHOLD=0.35
